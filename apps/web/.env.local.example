DATABASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
MAGIC_LINK_SECRET=
SITE_URL=
# Phase H.4c — transactional email via Resend.
# RESEND_API_KEY: get from https://resend.com/api-keys
# RESEND_FROM:    e.g. "Skitza <hello@skitza.app>" — must be a verified
#                 domain or the resend.dev sandbox sender.
# CRON_SECRET:    random string. Used by Vercel Cron + checked by
#                 /api/cron/session-reminders to authorize invocations.
RESEND_API_KEY=
RESEND_FROM=
CRON_SECRET=

# Phase H.5 — Stripe Connect Express + Checkout + webhooks.
# STRIPE_SECRET_KEY:     Stripe Dashboard → Developers → API keys (sk_test_… or sk_live_…)
# STRIPE_PUBLIC_KEY:     same screen (pk_test_… / pk_live_…). Currently unused server-side
#                        but exported for future Stripe.js client needs.
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard → Developers → Webhooks → your endpoint.
#                        Register `${SITE_URL}/api/stripe/webhook` and subscribe to
#                        checkout.session.completed, account.updated, charge.refunded.
# NEXT_PUBLIC_SITE_URL:  fully-qualified site origin used to build Stripe redirect URLs.
#                        Falls back to SITE_URL, then the canonical Vercel URL.
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=
