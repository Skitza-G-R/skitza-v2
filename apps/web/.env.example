# Skitza — web app environment variables
#
# Copy to .env.local (git-ignored) and fill in real values. Never
# commit .env.local. `NEXT_PUBLIC_*` vars ship to the browser.

# ─── Database (Neon Postgres) ──────────────────────────────────────
# Primary connection string. Used by packages/db and every server
# runtime (RSC, route handlers, server actions, tRPC, migrations).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Test database (used by packages/db integration tests). Typically a
# throwaway Neon branch or a local docker-postgres.
DATABASE_URL_TEST=postgresql://user:password@host/db_test?sslmode=require

# ─── Clerk (auth) ──────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com — Configure → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Webhook signing secret — Configure → Webhooks → endpoint's "Signing Secret"
CLERK_WEBHOOK_SECRET=whsec_xxx

# ─── Stripe Connect (payments) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── Resend (transactional email) ──────────────────────────────────
RESEND_API_KEY=re_xxx
# Verified sender address.
RESEND_FROM_EMAIL=Skitza <notifications@skitza.app>

# ─── R2 (audio + file storage) ─────────────────────────────────────
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=skitza-audio
R2_PUBLIC_HOST=https://pub-xxx.r2.dev

# ─── Magic links (artist view tokens) ──────────────────────────────
MAGIC_LINK_SECRET=change-me-to-32-bytes-of-random-hex

# ─── Cron auth ─────────────────────────────────────────────────────
# Bearer token Vercel's scheduled crons present to our /api/cron/* routes.
CRON_SECRET=change-me-to-random

# ─── Sentry (error tracking + perf) ────────────────────────────────
# Added 2026-04-22 — audit Task 14 observability.
#
# Get the DSN from https://sentry.io → Project → Settings → Client Keys.
# If unset, the SDK no-ops cleanly (no build failure, no runtime errors).
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Build-time source-map upload. Create an Internal Integration in
# Sentry's org settings with "Releases: Admin" scope, then paste here.
# Required only for production builds where you want symbolicated
# stack traces — optional in dev.
SENTRY_ORG=skitza
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=sntrys_xxx

# ─── PostHog (product analytics) ───────────────────────────────────
# Added 2026-04-22 — audit Task 14 observability.
#
# Get the project API key from https://app.posthog.com → Project
# Settings → API Keys. The host depends on your region — US projects
# use https://us.i.posthog.com; EU projects use https://eu.i.posthog.com.
# If unset, PostHog no-ops (no events captured, no errors thrown).
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
