{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skitza",
  "version": "0.0.0",
  "identifier": "com.skitza.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm --filter web dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../web/.next"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skitza",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
