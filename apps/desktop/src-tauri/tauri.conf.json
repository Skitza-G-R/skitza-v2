{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skitza",
  "version": "0.1.0",
  "identifier": "com.skitza.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm --filter web dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://skitza-v2-web.vercel.app"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skitza",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 20 },
        "backgroundColor": "#F4EFE7"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi"],
    "category": "Productivity",
    "shortDescription": "Skitza — your whole studio, in your dock.",
    "longDescription": "Skitza is the desktop shell for the Skitza web app. Native notifications, Finder drag-and-drop, a global ⌥⌘Space shortcut, and a menu bar that actually does something.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
